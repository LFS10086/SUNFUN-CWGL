{
  "name": "sanfeng-finance-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "package:win": "npm run build && electron-builder --win nsis portable --publish never",
    "lint": "oxlint",
    "preview": "vite preview",
    "qa": "node scripts/qa-playwright-check.cjs",
    "qa:cloud": "node scripts/cloud-e2e-check.cjs"
  },
  "build": {
    "appId": "com.sanfeng.finance",
    "productName": "三峰整装财务收支管理系统",
    "directories": {
      "output": "D:/workspace/sanfeng-finance-delivery/exe"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/sanfeng-official-mark.png",
      "public/sanfeng-official-mark.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "D:/workspace/sanfeng-ocr-plugin/engine/PaddleOCR-json_v1.4.1",
        "to": "app/ocr-plugin/PaddleOCR-json_v1.4.1"
      }
    ],
    "win": {
      "icon": "public/sanfeng-official-mark.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "三峰整装财务收支管理系统"
    }
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "vite": "^8.1.0"
  }
}
